# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template carries no secrets and belongs in the repo.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Re-stated by `vercel link`; the .env.example negation above must stay last.
.vercel
.env*
!.env.example
